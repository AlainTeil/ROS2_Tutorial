<?xml version="1.0"?>
<!--
  SimpleBot URDF — Lesson 24
  Differential-drive robot: box chassis, 2 drive wheels, 1 caster.
-->
<robot name="simplebot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== Materials ==================== -->
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>

  <!-- ==================== Base Link (Chassis) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <!-- Inertia of a box: Ixx=m/12*(y²+z²), etc. -->
      <inertia ixx="0.0458" ixy="0" ixz="0"
               iyy="0.0292" iyz="0" izz="0.0521"/>
    </inertial>
  </link>

  <!-- ==================== Left Wheel ==================== -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <!-- Inertia of a cylinder about its central axis -->
      <inertia ixx="0.000146" ixy="0" ixz="0"
               iyy="0.000146" iyz="0" izz="0.000625"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.16 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== Right Wheel ==================== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.000146" ixy="0" ixz="0"
               iyy="0.000146" iyz="0" izz="0.000625"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.16 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== Caster Wheel ==================== -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <!-- Inertia of a sphere: I = 2/5 * m * r² -->
      <inertia ixx="0.000025" ixy="0" ixz="0"
               iyy="0.000025" iyz="0" izz="0.000025"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.15 0 -0.025" rpy="0 0 0"/>
  </joint>

</robot>
